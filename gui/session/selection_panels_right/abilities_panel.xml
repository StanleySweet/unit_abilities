<?xml version="1.0" encoding="UTF-8"?>
<object name="unitAbilitiesPanel"
	size="6 6 100% 100%"
>
	<object>
		<repeat count="10">
			<object name="unitAbilitiesButton[n]" hidden="true" style="iconButton" type="button" size="0 0 38 38" tooltip_style="sessionToolTipBottom">
				<object name="unitAbilitiesIcon[n]" type="image" ghost="true" size="3 3 35 35"/>
				<object name="unitAbilitiesCount[n]" type="text" ghost="true" style="groupIconsText" size="0 18 100%-2 100%-2" text_align="right"/>
			</object>
		</repeat>
	</object>
</object>
